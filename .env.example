# ---- Solana ----
# Toggle between devnet and mainnet-beta with one variable
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# SPL reward token mint (create one on devnet, see README)
NEXT_PUBLIC_REWARD_TOKEN_MINT=

# Admin wallet — ONLY this wallet can trigger airdrops
NEXT_PUBLIC_ADMIN_WALLET=

# Server-side admin keypair path (base58 secret key) used to sign airdrop txs
ADMIN_SECRET_KEY=

# ---- Database ----
# Postgres in prod. SQLite works locally out of the box.
DATABASE_URL="file:./dev.db"
